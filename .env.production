# ---------------------------------------------------------------------------
# BuildIT Enterprise SEO Operations Platform — PRODUCTION CONFIGURATION
# ---------------------------------------------------------------------------

APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# Operational Modes
USE_MOCK_PROVIDERS=false
DEV_AUTH_BYPASS=false
TEST_MODE=false

# ---------------------------------------------------------------------------
# Paid API Infrastructure (Production Ready)
# ---------------------------------------------------------------------------

# DataForSEO
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Ahrefs
AHREFS_API_KEY=

# Hunter.io
HUNTER_IO_API_KEY=

# Outreach (Production Providers)
SENDGRID_API_KEY=
MAILGUN_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Infrastructure (Cloud / Managed)
# ---------------------------------------------------------------------------
POSTGRES_HOST=prod-db.cluster-xxxx.us-east-1.rds.amazonaws.com
REDIS_HOST=prod-redis.xxxx.cache.amazonaws.com
KAFKA_BOOTSTRAP_SERVERS=msk.xxxx.us-east-1.amazonaws.com:9092
TEMPORAL_HOST=temporal.cluster-xxxx.us-east-1.tmprl.cloud

# S3 (Production Bucket)
S3_BUCKET_NAME=buildit-production-assets
S3_REGION=us-east-1

# Auth (Clerk Production)
AUTH_PROVIDER=clerk
AUTH_ISSUER_URL=https://clerk.buildit.ai
AUTH_AUDIENCE=seo-platform-api
