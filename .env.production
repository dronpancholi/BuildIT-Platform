# ---------------------------------------------------------------------------
# BuildIT — Internal Demo / Production Configuration
# ---------------------------------------------------------------------------
# Internal use — no external auth, no subscriptions, no billing.
# All features work with zero-cost demo providers.
# ---------------------------------------------------------------------------

APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# Operational Modes
USE_MOCK_PROVIDERS=true
DEV_AUTH_BYPASS=true
TEST_MODE=false

# Auth — internal only, no Clerk
AUTH_PROVIDER=internal
AUTH_SECRET_KEY=internal-dev-key

# ---------------------------------------------------------------------------
# Infrastructure (Defaults for Docker Compose)
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
QDRANT_HOST=qdrant
QDRANT_PORT=6333
S3_ENDPOINT=http://minio:9000

# NVIDIA NIM — Live AI email generation (optional, omit to use deterministic fallback)
NVIDIA_NIM_API_KEY=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
NVIDIA_NIM_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_SEO_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_NIM_ORCHESTRATION_MODEL=DeepSeek-V4-Pro
NVIDIA_NIM_MEMORY_MODEL=MiniMax M2.7
NVIDIA_NIM_INFRA_MODEL=NVIDIA-Nemotron-3-Super-120B-A12B
NVIDIA_NIM_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
