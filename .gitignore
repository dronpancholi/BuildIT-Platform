# ============================================================================
# SEO Operations Platform — .gitignore
# ============================================================================

# Environment
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.so
.venv/
venv/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Node / Frontend
node_modules/
.next/
.turbo/
out/

# Docker
*.log

# Infrastructure
*.tfstate
*.tfstate.backup
.terraform/

# Secrets — NEVER commit
*.pem
*.key
secrets/
