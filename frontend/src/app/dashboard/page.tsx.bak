import { useState } from "react";
import Link from "next/link";
import { motion } from "framer-motion";
import {
  Users,
  Plus,
  Search,
  FileText,
  CheckCircle2,
  Clock,
  AlertTriangle,
  Megaphone,
  ClipboardList,
  Loader2,
  Activity,
  Bell,
  Zap,
  Pause,
  Play,
  ArrowRight,
  CheckCircle,
  XCircle,
  Mail,
  ShieldAlert,
  ChevronRight,
} from "lucide-react";
import { useApiList, useApiCreate } from "@/services/hooks";
import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query";
import { fetchApi } from "@/lib/api";
import { ENDPOINTS } from "@/services/endpoints";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
  DialogDescription,
  DialogFooter,
} from "@/components/ui/dialog";
import { Input } from "@/components/ui/input";
import { Select } from "@/components/ui/select";
import { cn } from "@/lib/utils";

// ── Types ──────────────────────────────────────────────

interface Client {
  id: string;
  name: string;
  domain: string;
  niche: string;
  business_type: string;
  status?: string;
  created_at?: string;
}

interface Campaign {
  id: string;
  name: string;
  client_id: string;
  campaign_type: string;
  status?: string;
  current_step?: number;
  total_steps?: number;
  last_activity_at?: string;
  owner?: string;
  prospects_count?: number;
  contacted_count?: number;
  replied_count?: number;
  links_acquired_count?: number;
}

interface Approval {
  id: string;
  status: string;
  summary?: string;
  risk_level?: string;
  sla_deadline?: string;
  created_at: string;
}

interface Execution {
  id: string;
  status: string;
}

interface OperationalEvent {
  id: string;
  event_type: string;
  summary: string;
  severity: string;
  metadata: Record<string, unknown> | null;
  created_at: string;
}

interface ExecutiveAlert {
  id: string;
  title: string;
  description: string | null;
  severity: string;
  status: string;
  source: string;
  occurred_at: string;
}

interface SystemHealth {
  status: string;
  components: { name: string; status: string; latency_ms?: number; message?: string | null }[];
}

interface ProviderHealth {
  provider: string;
  healthy: boolean;
  circuit_breaker_state?: string;
  last_error?: string;
}

// ── Constants ──────────────────────────────────────────

const NICHE_OPTIONS = [
  { label: "B2B SaaS", value: "B2B SaaS" },
  { label: "E-commerce", value: "E-commerce" },
  { label: "Healthcare", value: "Healthcare" },
  { label: "Legal", value: "Legal" },
  { label: "Real Estate", value: "Real Estate" },
  { label: "Local Services", value: "Local Services" },
  { label: "Content Publishing", value: "Content Publishing" },
  { label: "Agency", value: "Agency" },
  { label: "Education", value: "Education" },
  { label: "Finance", value: "Finance" },
  { label: "Technology", value: "Technology" },
  { label: "Hospitality", value: "Hospitality" },
  { label: "Manufacturing", value: "Manufacturing" },
  { label: "Non-profit", value: "Non-profit" },
];

const BUSINESS_TYPE_OPTIONS = [
  { label: "SaaS", value: "saas" },
  { label: "E-commerce Store", value: "ecommerce" },
  { label: "Agency", value: "agency" },
  { label: "Consultancy", value: "consultancy" },
  { label: "Marketplace", value: "marketplace" },
  { label: "Content Site", value: "content_site" },
  { label: "Local Business", value: "local_business" },
  { label: "Enterprise", value: "enterprise" },
];

const CAMPAIGN_TYPE_OPTIONS = [
  { label: "Guest Post", value: "guest_post" },
  { label: "Broken Link", value: "broken_link" },
  { label: "Resource Page", value: "resource_page" },
];

// ── Motion variants ────────────────────────────────────

const containerVariants = {
  hidden: { opacity: 0 },
  visible: {
    opacity: 1,
    transition: { staggerChildren: 0.05 },
  },
};

const itemVariants = {
  hidden: { opacity: 0, y: 12 },
  visible: { opacity: 1, y: 0 },
};

// ── Helpers ────────────────────────────────────────────

function relativeTime(iso: string): string {
  if (!iso) return "—";
  const then = new Date(iso).getTime();
  if (Number.isNaN(then)) return "—";
  const diff = Date.now() - then;
  const sec = Math.floor(diff / 1000);
  if (sec < 60) return `${sec}s ago`;
  const min = Math.floor(sec / 60);
  if (min < 60) return `${min}m ago`;
  const hr = Math.floor(min / 60);
  if (hr < 24) return `${hr}h ago`;
  const day = Math.floor(hr / 24);
  return `${day}d ago`;
}

function eventIcon(eventType: string) {
  const t = (eventType || "").toLowerCase();
  if (t.includes("email") || t.includes("outreach") || t.includes("sent")) return Mail;
  if (t.includes("approval") || t.includes("approve")) return CheckCircle;
  if (t.includes("reject")) return XCircle;
  if (t.includes("risk") || t.includes("alert") || t.includes("warning")) return ShieldAlert;
  return Activity;
}

function eventColor(severity: string): string {
  const s = (severity || "").toLowerCase();
  if (s === "critical" || s === "high" || s === "error") return "text-red-400";
  if (s === "warning" || s === "medium") return "text-amber-400";
  if (s === "success" || s === "info") return "text-emerald-400";
  return "text-slate-500";
}

function statusPillClass(status: string): string {
  const s = (status || "").toLowerCase();
  if (s === "running" || s === "active" || s === "healthy" || s === "ok") {
    return "bg-emerald-500/10 text-emerald-400 border-emerald-500/20";
  }
  if (s === "paused") {
    return "bg-amber-500/10 text-amber-400 border-amber-500/20";
  }
  if (s === "failed" || s === "error") {
    return "bg-red-500/10 text-red-400 border-red-500/20";
  }
  if (s === "completed" || s === "archived") {
    return "bg-slate-500/10 text-slate-400 border-slate-500/20";
  }
  return "bg-platform-500/10 text-platform-400 border-platform-500/20";
}

// ── Page ───────────────────────────────────────────────

export default function CommandCenter() {
  const queryClient = useQueryClient();

  const [clientDialogOpen, setClientDialogOpen] = useState(false);
  const [campaignDialogOpen, setCampaignDialogOpen] = useState(false);

  const [clientForm, setClientForm] = useState({
    name: "",
    domain: "",
    niche: "",
    business_type: "",
  });

  const [campaignForm, setCampaignForm] = useState({
    name: "",
    client_id: "",
    campaign_type: "",
  });

  // ── Queries ──

  const { data: clients = [], isLoading: loadingClients } = useApiList<Client>(
    ENDPOINTS.CLIENTS
  );
  const { data: campaigns = [], isLoading: loadingCampaigns } =
    useApiList<Campaign>(ENDPOINTS.CAMPAIGNS);
  const { data: approvals = [], isLoading: loadingApprovals } =
    useApiList<Approval>(ENDPOINTS.APPROVALS);
  const { data: events = [], isLoading: loadingEvents } = useApiList<OperationalEvent>(
    ENDPOINTS.OPERATIONS_FEED,
    { limit: 10 }
  );
  const { data: alerts = [] } = useApiList<ExecutiveAlert>(
    ENDPOINTS.EXECUTIVE_ALERTS,
    { limit: 5 }
  );

  // System health (lightweight)
  const { data: health } = useQuery<SystemHealth>({
    queryKey: [ENDPOINTS.HEALTH],
    queryFn: () => fetchApi<SystemHealth>(ENDPOINTS.HEALTH),
    refetchInterval: 30_000,
  });

  // Provider health (lightweight)
  const { data: providers = [] } = useQuery<ProviderHealth[]>({
    queryKey: ["/providers/health"],
    queryFn: () => fetchApi<ProviderHealth[]>("/providers/health"),
    refetchInterval: 30_000,
  });

  // ── Mutations ──

  const createClient = useApiCreate<Client, typeof clientForm>(
    ENDPOINTS.CLIENTS,
    {
      invalidateKeys: [ENDPOINTS.CLIENTS],
      successMessage: "Client created successfully",
    }
  );

  const createCampaign = useApiCreate<Campaign, typeof campaignForm>(
    ENDPOINTS.CAMPAIGNS,
    {
      invalidateKeys: [ENDPOINTS.CAMPAIGNS],
      successMessage: "Campaign created successfully",
    }
  );

  const pauseCampaign = useMutation({
    mutationFn: ({ id, action }: { id: string; action: "pause" | "resume" }) =>
      fetchApi(`/campaigns/${id}/${action}`, { method: "POST" }),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: [ENDPOINTS.CAMPAIGNS] });
    },
  });

  const handleCreateClient = async () => {
    await createClient.mutateAsync(clientForm);
    if (!createClient.isError) {
      setClientDialogOpen(false);
      setClientForm({ name: "", domain: "", niche: "", business_type: "" });
    }
  };

  const handleCreateCampaign = async () => {
    await createCampaign.mutateAsync(campaignForm);
    if (!createCampaign.isError) {
      setCampaignDialogOpen(false);
      setCampaignForm({ name: "", client_id: "", campaign_type: "" });
    }
  };

  // ── Derived state ──

  const pendingApprovals = approvals.filter((a) => a.status === "pending");
  const overdueApprovals = pendingApprovals.filter(
    (a) => a.sla_deadline && new Date(a.sla_deadline).getTime() < Date.now()
  );
  const activeCampaigns = campaigns.filter(
    (c) => (c.status || "running") === "running" || c.status === "active"
  );
  const stuckCampaigns = activeCampaigns.filter((c) => {
    if (!c.last_activity_at) return false;
    const idleMin = (Date.now() - new Date(c.last_activity_at).getTime()) / 60000;
    return idleMin > 60;
  });
  const failedComponents = (health?.components || []).filter(
    (c) => c.status === "unhealthy" || c.status === "degraded"
  );
  const downProviders = providers.filter(
    (p) => !p.healthy || p.circuit_breaker_state === "open"
  );
  const openAlerts = alerts.filter((a) => a.status === "open");

  // ── Zone 1: System status ──

  const isEmergency = downProviders.length > 0 || failedComponents.length > 0 || openAlerts.length > 0;
  const statusLabel = isEmergency
    ? downProviders.length > 0
      ? "DEGRADED"
      : failedComponents.length > 0
        ? "DEGRADED"
        : "ATTENTION REQUIRED"
    : "FULLY OPERATIONAL";
  const statusColor = isEmergency
    ? "bg-amber-500/10 text-amber-400 border-amber-500/20"
    : "bg-emerald-500/10 text-emerald-400 border-emerald-500/20";
  const statusDot = isEmergency ? "bg-amber-400" : "bg-emerald-400";

  const statusSubtext: string[] = [];
  if (downProviders.length > 0) {
    statusSubtext.push(
      `${downProviders.length} provider${downProviders.length === 1 ? "" : "s"} down: ${downProviders.map((p) => p.provider).join(", ")}`
    );
  }
  if (failedComponents.length > 0) {
    statusSubtext.push(
      `${failedComponents.length} component${failedComponents.length === 1 ? "" : "s"} degraded`
    );
  }
  if (openAlerts.length > 0) {
    statusSubtext.push(
      `${openAlerts.length} open alert${openAlerts.length === 1 ? "" : "s"}`
    );
  }
  if (statusSubtext.length === 0) {
    statusSubtext.push("All systems normal");
  }

  // ── Zone 2: Action required cards ──

  type ActionCard = {
    id: string;
    title: string;
    detail: string;
    icon: React.ReactNode;
    severity: "critical" | "warning" | "info";
    href: string;
    cta: string;
  };
  const actionCards: ActionCard[] = [];

  if (pendingApprovals.length > 0) {
    const dueSoon = pendingApprovals.filter(
      (a) => a.sla_deadline && new Date(a.sla_deadline).getTime() - Date.now() < 3600000
    );
    const overdue = overdueApprovals.length;
    let detail = `${pendingApprovals.length} pending approval${pendingApprovals.length === 1 ? "" : "s"}`;
    const parts: string[] = [];
    if (overdue > 0) parts.push(`${overdue} OVERDUE`);
    if (dueSoon.length > 0) parts.push(`${dueSoon.length} due in 1h`);
    if (parts.length > 0) detail += ` • ${parts.join(" • ")}`;
    actionCards.push({
      id: "approvals",
      title: "Email Approvals",
      detail,
      icon: <ClipboardList className="w-5 h-5" />,
      severity: overdue > 0 ? "critical" : dueSoon.length > 0 ? "warning" : "info",
      href: "/dashboard/approvals",
      cta: "Open approvals",
    });
  }
  if (stuckCampaigns.length > 0) {
    actionCards.push({
      id: "stuck-workflows",
      title: "Stuck Workflows",
      detail: `${stuckCampaigns.length} campaign${stuckCampaigns.length === 1 ? "" : "s"} idle > 1h`,
      icon: <Clock className="w-5 h-5" />,
      severity: "warning",
      href: `/dashboard/campaigns/${stuckCampaigns[0].id}`,
      cta: "View campaign",
    });
  }
  if (downProviders.length > 0) {
    actionCards.push({
      id: "providers-down",
      title: "Providers Down",
      detail: `${downProviders.map((p) => p.provider).join(", ")} unavailable`,
      icon: <AlertTriangle className="w-5 h-5" />,
      severity: "critical",
      href: "/dashboard/providers",
      cta: "View providers",
    });
  }
  if (openAlerts.length > 0) {
    actionCards.push({
      id: "alerts",
      title: "Open Alerts",
      detail: `${openAlerts.length} alert${openAlerts.length === 1 ? "" : "s"} from executive monitoring`,
      icon: <Bell className="w-5 h-5" />,
      severity: "warning",
      href: "/dashboard/executive",
      cta: "View alerts",
    });
  }
  const visibleActionCards = actionCards.slice(0, 3);

  // ── Customer cards ──

  const customerHealth = (c: Client) => {
    const campaignsForCustomer = campaigns.filter((cam) => cam.client_id === c.id);
    const active = campaignsForCustomer.filter(
      (cam) => (cam.status || "running") === "running"
    ).length;
    const customerApprovals = pendingApprovals.filter(
      (a) => a.status === "pending"
    ).length;
    if (customerApprovals > 0) return "attention" as const;
    if (campaignsForCustomer.length === 0) return "paused" as const;
    if (active === 0) return "paused" as const;
    return "healthy" as const;
  };
  const customerHealthColor = (h: "healthy" | "attention" | "paused" | "failed") => {
    if (h === "healthy") return "bg-emerald-500/10 text-emerald-400 border-emerald-500/20";
    if (h === "attention") return "bg-amber-500/10 text-amber-400 border-amber-500/20";
    if (h === "failed") return "bg-red-500/10 text-red-400 border-red-500/20";
    return "bg-slate-500/10 text-slate-400 border-slate-500/20";
  };

  const clientOptions = clients.map((c) => ({ label: c.name, value: c.id }));

  return (
    <motion.div
      className="space-y-6"
      variants={containerVariants}
      initial="hidden"
      animate="visible"
    >
      {/* ── Header ── */}
      <motion.div
        variants={itemVariants}
        className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4"
      >
        <div className="flex items-center gap-3">
          <div className="w-10 h-10 rounded-xl bg-platform-600/20 border border-platform-500/20 flex items-center justify-center">
            <Zap className="w-5 h-5 text-platform-400" />
          </div>
          <div>
            <h1 className="text-2xl font-bold text-slate-100 tracking-tight">
              Command Center
            </h1>
            <p className="text-slate-500 text-sm">
              Mission control for your SEO operations
            </p>
          </div>
        </div>
        <div className="flex flex-wrap gap-2">
          <Button
            size="sm"
            onClick={() => setClientDialogOpen(true)}
            className="flex items-center gap-1.5"
            data-testid="command-center-new-client"
          >
            <Plus className="w-3.5 h-3.5" /> New Client
          </Button>
          <Button
            size="sm"
            variant="outline"
            onClick={() => setCampaignDialogOpen(true)}
            className="flex items-center gap-1.5"
            data-testid="command-center-new-campaign"
          >
            <Megaphone className="w-3.5 h-3.5" /> New Campaign
          </Button>
        </div>
      </motion.div>

      {/* ── ZONE 1: System Status ── */}
      <motion.div
        variants={itemVariants}
        className={cn(
          "glass-panel p-4 border-l-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3",
          isEmergency ? "border-l-amber-500" : "border-l-emerald-500"
        )}
        data-testid="zone-status"
        aria-label="System status"
      >
        <div className="flex items-center gap-3 min-w-0">
          <span
            className={cn(
              "w-2.5 h-2.5 rounded-full shrink-0",
              statusDot,
              !isEmergency && "animate-pulse"
            )}
          />
          <div className="min-w-0">
            <div className="flex items-center gap-2 flex-wrap">
              <span
                className={cn(
                  "text-xs font-mono font-bold px-2 py-0.5 rounded border",
                  statusColor
                )}
              >
                {statusLabel}
              </span>
              {statusSubtext.map((s, i) => (
                <span key={i} className="text-sm text-slate-300">
                  {s}
                </span>
              ))}
            </div>
          </div>
        </div>
        <Link
          href="/dashboard/system"
          className="text-xs font-mono text-platform-400 hover:text-platform-300 flex items-center gap-1 shrink-0"
        >
          View system status <ChevronRight className="w-3.5 h-3.5" />
        </Link>
      </motion.div>

      {/* ── ZONE 2: Action Required ── */}
      <motion.div variants={itemVariants} data-testid="zone-action-required">
        <div className="flex items-center justify-between mb-3">
          <h2 className="text-sm font-semibold text-slate-400 uppercase tracking-wider flex items-center gap-2">
            <AlertTriangle className="w-4 h-4" /> Action Required
            {actionCards.length > 0 && (
              <span className="ml-1 px-1.5 py-0.5 rounded-full text-[10px] font-mono bg-amber-500/10 text-amber-400 border border-amber-500/20">
                {actionCards.length}
              </span>
            )}
          </h2>
        </div>
        {visibleActionCards.length === 0 ? (
          <div className="glass-panel p-5 flex items-center gap-3 border-l-4 border-l-emerald-500">
            <CheckCircle2 className="w-5 h-5 text-emerald-400 shrink-0" />
            <div>
              <p className="text-sm text-slate-200 font-medium">All caught up.</p>
              <p className="text-xs text-slate-500">Nothing needs your attention right now.</p>
            </div>
          </div>
        ) : (
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-3">
            {visibleActionCards.map((card) => {
              const borderColor =
                card.severity === "critical"
                  ? "border-l-red-500"
                  : card.severity === "warning"
                    ? "border-l-amber-500"
                    : "border-l-platform-500";
              const iconColor =
                card.severity === "critical"
                  ? "text-red-400"
                  : card.severity === "warning"
                    ? "text-amber-400"
                    : "text-platform-400";
              return (
                <Link
                  key={card.id}
                  href={card.href}
                  className={cn(
                    "glass-panel p-4 border-l-4 hover:bg-surface-border/10 transition-colors group",
                    borderColor
                  )}
                  data-testid={`action-card-${card.id}`}
                >
                  <div className="flex items-start gap-3">
                    <div className={cn("mt-0.5 shrink-0", iconColor)}>{card.icon}</div>
                    <div className="flex-1 min-w-0">
                      <p className="text-sm font-medium text-slate-100">{card.title}</p>
                      <p className="text-xs text-slate-400 mt-0.5">{card.detail}</p>
                      <p className="text-[11px] font-mono text-platform-400 mt-2 group-hover:text-platform-300 flex items-center gap-1">
                        {card.cta} <ArrowRight className="w-3 h-3" />
                      </p>
                    </div>
                  </div>
                </Link>
              );
            })}
          </div>
        )}
      </motion.div>

      {/* ── ZONE 3: Customers ── */}
      <motion.div variants={itemVariants} data-testid="zone-customers">
        <div className="flex items-center justify-between mb-3">
          <h2 className="text-sm font-semibold text-slate-400 uppercase tracking-wider flex items-center gap-2">
            <Users className="w-4 h-4" /> Customers ({clients.length})
          </h2>
          <Link
            href="/dashboard/customers"
            className="text-xs font-mono text-slate-500 hover:text-platform-400 flex items-center gap-1"
          >
            View all <ChevronRight className="w-3.5 h-3.5" />
          </Link>
        </div>
        {loadingClients ? (
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {[1, 2, 3].map((i) => (
              <div key={i} className="glass-panel p-4 animate-pulse h-32" />
            ))}
          </div>
        ) : clients.length === 0 ? (
          <div className="glass-panel p-8 text-center">
            <Users className="w-10 h-10 text-slate-700 mx-auto mb-3" />
            <p className="text-sm text-slate-300 font-medium">No customers yet</p>
            <p className="text-xs text-slate-500 mt-1 mb-4">
              Add your first customer to start building campaigns.
            </p>
            <Button
              size="sm"
              onClick={() => setClientDialogOpen(true)}
              data-testid="empty-state-add-customer"
            >
              <Plus className="w-3.5 h-3.5 mr-1" /> Add Customer
            </Button>
          </div>
        ) : (
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {clients.slice(0, 6).map((c) => {
              const health = customerHealth(c);
              const customerCampaigns = campaigns.filter(
                (cam) => cam.client_id === c.id
              );
              const activeCount = customerCampaigns.filter(
                (cam) => (cam.status || "running") === "running"
              ).length;
              return (
                <Link
                  key={c.id}
                  href={`/dashboard/customers/${c.id}`}
                  className="glass-panel p-4 hover:border-platform-500/30 transition-colors group"
                  data-testid={`customer-card-${c.id}`}
                >
                  <div className="flex items-start justify-between gap-2 mb-2">
                    <div className="min-w-0">
                      <p className="text-sm font-medium text-slate-100 truncate">
                        {c.name}
                      </p>
                      <p className="text-[11px] font-mono text-slate-500 truncate">
                        {c.domain || c.niche}
                      </p>
                    </div>
                    <span
                      className={cn(
                        "shrink-0 text-[10px] font-mono font-bold uppercase px-1.5 py-0.5 rounded border",
                        customerHealthColor(health)
                      )}
                    >
                      {health}
                    </span>
                  </div>
                  <div className="grid grid-cols-2 gap-2 mt-3 pt-3 border-t border-surface-border/50 text-[11px]">
                    <div>
                      <p className="text-slate-500 font-mono">Campaigns</p>
                      <p className="text-slate-200 font-medium">
                        {customerCampaigns.length}
                        {activeCount > 0 && (
                          <span className="text-emerald-400 ml-1">
                            ({activeCount} active)
                          </span>
                        )}
                      </p>
                    </div>
                    <div>
                      <p className="text-slate-500 font-mono">Pending</p>
                      <p className="text-slate-200 font-medium">
                        {pendingApprovals.length}
                      </p>
                    </div>
                  </div>
                </Link>
              );
            })}
          </div>
        )}
      </motion.div>

      {/* ── ZONE 4: Active Campaigns ── */}
      <motion.div variants={itemVariants} data-testid="zone-active-campaigns">
        <div className="flex items-center justify-between mb-3">
          <h2 className="text-sm font-semibold text-slate-400 uppercase tracking-wider flex items-center gap-2">
            <Megaphone className="w-4 h-4" /> Active Campaigns ({activeCampaigns.length})
          </h2>
          <Link
            href="/dashboard/campaigns"
            className="text-xs font-mono text-slate-500 hover:text-platform-400 flex items-center gap-1"
          >
            View all <ChevronRight className="w-3.5 h-3.5" />
          </Link>
        </div>
        {loadingCampaigns ? (
          <div className="space-y-2">
            {[1, 2].map((i) => (
              <div key={i} className="glass-panel p-4 animate-pulse h-16" />
            ))}
          </div>
        ) : activeCampaigns.length === 0 ? (
          <div className="glass-panel p-6 text-center">
            <Megaphone className="w-8 h-8 text-slate-700 mx-auto mb-2" />
            <p className="text-sm text-slate-300">No active campaigns</p>
            <p className="text-xs text-slate-500 mt-1 mb-3">
              Create a campaign to start outreach.
            </p>
            <Button size="sm" variant="outline" onClick={() => setCampaignDialogOpen(true)}>
              <Plus className="w-3.5 h-3.5 mr-1" /> New Campaign
            </Button>
          </div>
        ) : (
          <div className="space-y-2">
            {activeCampaigns.slice(0, 5).map((c) => {
              const step = c.current_step || 0;
              const total = c.total_steps || 8;
              const lastActivity = c.last_activity_at
                ? relativeTime(c.last_activity_at)
                : "no activity";
              const stale = c.last_activity_at
                ? (Date.now() - new Date(c.last_activity_at).getTime()) / 60000 > 60
                : true;
              return (
                <div
                  key={c.id}
                  className="glass-panel p-3 flex items-center gap-3 hover:border-platform-500/30 transition-colors"
                  data-testid={`active-campaign-${c.id}`}
                >
                  <Link
                    href={`/dashboard/campaigns/${c.id}`}
                    className="flex-1 min-w-0 group"
                  >
                    <div className="flex items-center gap-2 flex-wrap">
                      <p className="text-sm font-medium text-slate-100 group-hover:text-platform-300 truncate">
                        {c.name}
                      </p>
                      <span
                        className={cn(
                          "shrink-0 text-[10px] font-mono font-bold uppercase px-1.5 py-0.5 rounded border",
                          statusPillClass(c.status || "running")
                        )}
                      >
                        {c.status || "running"}
                      </span>
                      <span className="text-[10px] font-mono text-slate-500">
                        Step {step}/{total}
                      </span>
                    </div>
                    <div className="flex items-center gap-3 mt-1.5 text-[11px] text-slate-500">
                      <span
                        className={cn(
                          "flex items-center gap-1",
                          stale ? "text-amber-400" : "text-slate-500"
                        )}
                        title={c.last_activity_at}
                      >
                        <Clock className="w-3 h-3" /> {lastActivity}
                      </span>
                      {c.prospects_count !== undefined && (
                        <span>
                          {c.prospects_count} prospects · {c.contacted_count ?? 0} contacted
                        </span>
                      )}
                    </div>
                  </Link>
                  <div className="flex items-center gap-1 shrink-0">
                    <Button
                      size="sm"
                      variant="outline"
                      onClick={() =>
                        pauseCampaign.mutate({ id: c.id, action: "pause" })
                      }
                      disabled={pauseCampaign.isPending}
                      aria-label={`Pause ${c.name}`}
                      data-testid={`pause-campaign-${c.id}`}
                    >
                      <Pause className="w-3.5 h-3.5" />
                    </Button>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </motion.div>

      {/* ── ZONE 5: Recent Events ── */}
      <motion.div variants={itemVariants} data-testid="zone-recent-events">
        <Card>
          <CardHeader className="pb-3">
            <CardTitle className="text-sm font-semibold text-slate-400 uppercase tracking-wider flex items-center gap-2">
              <Activity className="w-4 h-4" /> Recent Activity
            </CardTitle>
          </CardHeader>
          <CardContent>
            {loadingEvents ? (
              <div className="flex justify-center py-8">
                <Loader2 className="w-5 h-5 text-platform-500 animate-spin" />
              </div>
            ) : events.length === 0 ? (
              <div className="py-8 text-center">
                <Activity className="w-8 h-8 text-slate-700 mx-auto mb-2" />
                <p className="text-sm text-slate-500">No recent activity yet.</p>
                <p className="text-xs text-slate-600 mt-1">
                  Operational events will appear here as workflows run.
                </p>
              </div>
            ) : (
              <div className="space-y-2.5">
                {events.slice(0, 10).map((item) => {
                  const Icon = eventIcon(item.event_type);
                  return (
                    <div
                      key={item.id}
                      className="flex items-center justify-between py-1.5 border-b border-surface-border/50 last:border-0 gap-3"
                    >
                      <div className="flex items-center gap-2.5 min-w-0 flex-1">
                        <Icon
                          className={cn("w-3.5 h-3.5 shrink-0", eventColor(item.severity))}
                        />
                        <p className="text-sm text-slate-200 truncate">
                          {item.summary || item.event_type}
                        </p>
                      </div>
                      <span className="text-[10px] font-mono text-slate-600 whitespace-nowrap shrink-0">
                        {relativeTime(item.created_at)}
                      </span>
                    </div>
                  );
                })}
              </div>
            )}
          </CardContent>
        </Card>
      </motion.div>

      {/* ── Create Client Dialog ── */}
      <Dialog open={clientDialogOpen} onOpenChange={setClientDialogOpen}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>New Client</DialogTitle>
            <DialogDescription>
              Add a new client to your portfolio.
            </DialogDescription>
          </DialogHeader>
          <div className="space-y-4 py-2">
            <div className="space-y-2">
              <label className="text-sm font-medium text-slate-300">Client Name</label>
              <Input
                placeholder="e.g. Acme Corp"
                value={clientForm.name}
                onChange={(e) =>
                  setClientForm((f) => ({ ...f, name: e.target.value }))
                }
              />
            </div>
            <div className="space-y-2">
              <label className="text-sm font-medium text-slate-300">Domain</label>
              <Input
                placeholder="e.g. acme.com"
                value={clientForm.domain}
                onChange={(e) =>
                  setClientForm((f) => ({ ...f, domain: e.target.value }))
                }
              />
            </div>
            <div className="space-y-2">
              <label className="text-sm font-medium text-slate-300">Niche</label>
              <Select
                options={NICHE_OPTIONS}
                placeholder="Select niche"
                value={clientForm.niche}
                onChange={(e) =>
                  setClientForm((f) => ({ ...f, niche: e.target.value }))
                }
              />
            </div>
            <div className="space-y-2">
              <label className="text-sm font-medium text-slate-300">
                Business Type
              </label>
              <Select
                options={BUSINESS_TYPE_OPTIONS}
                placeholder="Select type"
                value={clientForm.business_type}
                onChange={(e) =>
                  setClientForm((f) => ({
                    ...f,
                    business_type: e.target.value,
                  }))
                }
              />
            </div>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setClientDialogOpen(false)}>
              Cancel
            </Button>
            <Button
              onClick={handleCreateClient}
              disabled={
                !clientForm.name || !clientForm.domain || createClient.isPending
              }
            >
              {createClient.isPending ? (
                <Loader2 className="w-4 h-4 animate-spin" />
              ) : (
                "Create Client"
              )}
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* ── Create Campaign Dialog ── */}
      <Dialog open={campaignDialogOpen} onOpenChange={setCampaignDialogOpen}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>New Campaign</DialogTitle>
            <DialogDescription>
              Launch a new link-building campaign.
            </DialogDescription>
          </DialogHeader>
          <div className="space-y-4 py-2">
            <div className="space-y-2">
              <label className="text-sm font-medium text-slate-300">
                Campaign Name
              </label>
              <Input
                placeholder="e.g. Q1 Guest Post Push"
                value={campaignForm.name}
                onChange={(e) =>
                  setCampaignForm((f) => ({ ...f, name: e.target.value }))
                }
              />
            </div>
            <div className="space-y-2">
              <label className="text-sm font-medium text-slate-300">Client</label>
              <Select
                options={clientOptions}
                placeholder="Select client"
                value={campaignForm.client_id}
                onChange={(e) =>
                  setCampaignForm((f) => ({
                    ...f,
                    client_id: e.target.value,
                  }))
                }
              />
            </div>
            <div className="space-y-2">
              <label className="text-sm font-medium text-slate-300">
                Campaign Type
              </label>
              <Select
                options={CAMPAIGN_TYPE_OPTIONS}
                placeholder="Select type"
                value={campaignForm.campaign_type}
                onChange={(e) =>
                  setCampaignForm((f) => ({
                    ...f,
                    campaign_type: e.target.value,
                  }))
                }
              />
            </div>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setCampaignDialogOpen(false)}>
              Cancel
            </Button>
            <Button
              onClick={handleCreateCampaign}
              disabled={
                !campaignForm.name ||
                !campaignForm.client_id ||
                !campaignForm.campaign_type ||
                createCampaign.isPending
              }
            >
              {createCampaign.isPending ? (
                <Loader2 className="w-4 h-4 animate-spin" />
              ) : (
                "Create Campaign"
              )}
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </motion.div>
  );
}
